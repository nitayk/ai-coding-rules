## Promise.allSettled for Multiple Operations

**Use Promise.allSettled when all results matter, including failures:**

```typescript
// Good: Handle both success and failure
async function fetchMultipleUsers(ids: string[]): Promise<UserResult[]> {
  const results = await Promise.allSettled(
    ids.map(id => fetchUser(id))
  );
  return results.map((result, i) => {
    if (result.status === "fulfilled") {
      return { id: ids[i], user: result.value, error: null };
    }
    return { id: ids[i], user: null, error: result.reason };
  });
}

// Bad: Promise.all short-circuits on first rejection
const users = await Promise.all(ids.map(fetchUser));  // Fails entirely if one fails
```

